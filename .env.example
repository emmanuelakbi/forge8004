# --- Server-only (never exposed to the browser) ---

# Groq AI — required for trade cycles and market sentiment
GROQ_API_KEY=

# Production URL — used for SEO sitemap and canonical links
APP_URL=https://forge8004.vercel.app

# Hardhat contract deployment (server-only, never commit the real key)
DEPLOYER_PRIVATE_KEY=

# --- Client-side (NEXT_PUBLIC_* prefix exposes vars to the browser) ---

# Base Sepolia JSON-RPC endpoint
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org

# Contract registry addresses on Base Sepolia
NEXT_PUBLIC_IDENTITY_REGISTRY=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_REPUTATION_REGISTRY=0x2345678901234567890123456789012345678901
NEXT_PUBLIC_VALIDATION_REGISTRY=0x3456789012345678901234567890123456789012
NEXT_PUBLIC_RISK_ROUTER=0x4567890123456789012345678901234567890123
NEXT_PUBLIC_VAULT=0x5678901234567890123456789012345678901234
NEXT_PUBLIC_CAPITAL_VAULT=0x0000000000000000000000000000000000000000
