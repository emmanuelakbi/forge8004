{
  "entities": {
    "Agent": {
      "title": "Agent",
      "description": "An autonomous trading agent registered on the protocol.",
      "type": "object",
      "properties": {
        "agentId": { "type": "string", "description": "Unique identifier for the agent." },
        "name": { "type": "string", "description": "Display name of the agent." },
        "description": { "type": "string", "description": "Technical description of the strategy." },
        "strategyType": { "type": "string", "description": "The trading strategy employed (e.g., GRID_TRADING)." },
        "riskProfile": { "type": "string", "description": "Risk tolerance level (e.g., aggressive, balanced)." },
        "avatarUrl": { "type": "string", "description": "URL to the agent's avatar image." },
        "owner": { "type": "string", "description": "Wallet address of the agent's owner." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when the agent was registered." }
      },
      "required": ["agentId", "name", "owner"]
    },
    "Reputation": {
      "title": "Reputation",
      "description": "Performance metrics for an agent.",
      "type": "object",
      "properties": {
        "agentId": { "type": "string" },
        "cumulativePnl": { "type": "number" },
        "totalFunds": { "type": "number" },
        "maxDrawdown": { "type": "number" },
        "tradesCount": { "type": "integer" },
        "sharpeLikeScore": { "type": "number" }
      },
      "required": ["agentId"]
    },
    "Validation": {
      "title": "Validation",
      "description": "A validation record from a protocol node.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agentId": { "type": "string" },
        "validator": { "type": "string" },
        "score": { "type": "number" },
        "comment": { "type": "string" },
        "validationType": { "type": "string" },
        "timestamp": { "type": "integer" }
      },
      "required": ["id", "agentId", "validator", "score"]
    },
    "PnLPoint": {
      "title": "PnLPoint",
      "description": "A single point in time for profit and loss tracking.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "integer" },
        "value": { "type": "number" }
      },
      "required": ["timestamp", "value"]
    },
    "VaultTransaction": {
      "title": "VaultTransaction",
      "description": "A record of a vault deposit or funding event.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agentId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string" },
        "status": { "type": "string" },
        "txHash": { "type": "string" },
        "timestamp": { "type": "integer" }
      },
      "required": ["id", "agentId", "amount", "type", "status", "timestamp"]
    },
    "TradeIntent": {
      "title": "TradeIntent",
      "description": "A signal or trade intent generated by an agent.",
      "type": "object",
      "properties": {
        "agentId": { "type": "string" },
        "side": { "type": "string" },
        "size": { "type": "number" },
        "entryPrice": { "type": "number" },
        "exitPrice": { "type": "number" },
        "takeProfit": { "type": "number" },
        "stopLoss": { "type": "number" },
        "status": { "type": "string" },
        "timestamp": { "type": "integer" }
      },
      "required": ["agentId", "side", "size", "entryPrice", "status", "timestamp"]
    },
    "ActivePositions": {
      "title": "ActivePositions",
      "description": "List of currently open trade positions for an agent.",
      "type": "object",
      "properties": {
        "agentId": { "type": "string" },
        "positions": { "type": "array", "items": { "$ref": "TradeIntent" } },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["agentId", "positions"]
    }
  },
  "firestore": {
    "/agents/{agentId}": {
      "schema": "Agent",
      "description": "Collection of registered agents."
    },
    "/reputation/{agentId}": {
      "schema": "Reputation",
      "description": "Performance metrics indexed by agent ID."
    },
    "/agents/{agentId}/validations/{validationId}": {
      "schema": "Validation",
      "description": "Validation history for a specific agent."
    },
    "/agents/{agentId}/pnl_history/{pointId}": {
      "schema": "PnLPoint",
      "description": "Historical PnL data points for an agent."
    },
    "/agents/{agentId}/vault_transactions/{txId}": {
      "schema": "VaultTransaction",
      "description": "History of vault deposits and capital funding."
    },
    "/agents/{agentId}/intents/{intentId}": {
      "schema": "TradeIntent",
      "description": "Trade signals and intents generated by the agent."
    },
    "/active_positions/{agentId}": {
      "schema": "ActivePositions",
      "description": "Currently open trade positions for an agent."
    }
  }
}
